<Window x:Class="ClearSkies.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClearSkies"
        Width="620" Height="760"
        MinWidth="520" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Loaded="Window_Loaded">

    <!-- Outer border gives the window its rounded shape -->
    <Border Background="{StaticResource WindowBgBrush}"
            CornerRadius="12" BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1" Margin="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title bar (dedicated drag area) -->
            <Border Grid.Row="0" Background="Transparent" CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel Margin="16,0">
                    <!-- App icon + title -->
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <TextBlock Text="ClearSkies"
                                   Foreground="{StaticResource SubtextBrush}"
                                   FontSize="12" VerticalAlignment="Center" />
                        <TextBlock x:Name="lblVersion"
                                   Foreground="{StaticResource SubtextBrush}"
                                   FontSize="10" VerticalAlignment="Center"
                                   Margin="6,1,0,0" Opacity="0.6" />
                    </StackPanel>

                    <!-- Window controls -->
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button x:Name="btnRunAsAdmin" Content="Run as Admin"
                                FontFamily="Segoe UI" FontSize="10"
                                Style="{StaticResource DarkButton}" Padding="10,5" Margin="0,0,6,0"
                                BorderThickness="0" Click="BtnRunAsAdmin_Click" ToolTip="Restart as Administrator"
                                Foreground="{StaticResource AccentBrush}" />
                        <Button Content="&#xE949;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                Style="{StaticResource DarkButton}" Padding="10,5" Margin="0,0,2,0"
                                BorderThickness="0" Click="BtnMinimize_Click" ToolTip="Minimize" />
                        <Button Content="&#xE106;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                Style="{StaticResource DangerButton}" Padding="10,5"
                                BorderThickness="0" Click="BtnExit_Click" ToolTip="Close" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Main content -->
            <Grid Grid.Row="1" Margin="20,4,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Status + total bar -->
                <Border Grid.Row="0" Style="{StaticResource PanelBorder}" Padding="16,12" Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Name="lblStatus" Text="Ready"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="13" FontWeight="SemiBold" />
                            <ProgressBar x:Name="progressBar"
                                         Style="{StaticResource DarkProgressBar}"
                                         Margin="0,6,0,0" />
                        </StackPanel>
                        <TextBlock x:Name="lblTotalSize" Text="0 B"
                                   Grid.Column="1"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="20" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="16,0,0,0" />
                    </Grid>
                </Border>

                <!-- Cache items -->
                <StackPanel x:Name="pnlCheckboxes" Grid.Row="1" Margin="0,4,0,0" />

                <!-- Action bar -->
                <Grid Grid.Row="2" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="btnCleanSelected"
                            Style="{StaticResource AccentButton}"
                            Padding="20,14"
                            Grid.Column="0" HorizontalAlignment="Stretch"
                            Margin="0,0,8,0"
                            Click="BtnCleanSelected_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Run Selected" FontSize="14" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="btnSelectAll" Content="All"
                                Style="{StaticResource DarkButton}" Padding="12,8"
                                Margin="0,0,4,0" Click="BtnSelectAll_Click" />
                        <Button x:Name="btnDeselectAll" Content="None"
                                Style="{StaticResource DarkButton}" Padding="12,8"
                                Margin="0,0,4,0" Click="BtnDeselectAll_Click" />
                        <Button x:Name="btnSchedule" Content="&#xE787;"
                                FontFamily="Segoe MDL2 Assets" ToolTip="Schedule"
                                Style="{StaticResource DarkButton}" Padding="10,8"
                                Click="BtnSchedule_Click" />
                    </StackPanel>
                </Grid>

                <!-- Log section (fills remaining space) -->
                <DockPanel Grid.Row="3" Margin="0,16,0,0">
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                        <TextBlock Text="Log" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource SubtextBrush}"
                                   DockPanel.Dock="Left" VerticalAlignment="Center" />
                        <Button x:Name="btnClearLog" Content="Clear"
                                Style="{StaticResource DarkButton}"
                                Padding="10,3" FontSize="10"
                                DockPanel.Dock="Right" HorizontalAlignment="Right"
                                Click="BtnClearLog_Click" />
                    </DockPanel>

                    <Border CornerRadius="8"
                            Background="{StaticResource LogBgBrush}"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="1">
                        <TextBox x:Name="txtLog"
                                 IsReadOnly="True"
                                 FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11"
                                 Foreground="{StaticResource SubtextBrush}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="12,10"
                                 VerticalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True" />
                    </Border>
                </DockPanel>

            </Grid>
        </Grid>
    </Border>
</Window>
