<Window x:Class="ShaderCacheCleaner.ScheduleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Schedule Automatic Cleaning"
        Width="460" Height="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Loaded="Window_Loaded">

    <Border Background="{StaticResource WindowBgBrush}"
            CornerRadius="12" BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1" Margin="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="Transparent" CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel Margin="16,0">
                    <TextBlock Text="Schedule Automatic Cleaning"
                               Foreground="{StaticResource SubtextBrush}"
                               FontSize="12" VerticalAlignment="Center"
                               DockPanel.Dock="Left" />
                    <Button Content="&#xE106;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                            Style="{StaticResource DangerButton}" Padding="10,5"
                            BorderThickness="0" Click="BtnClose_Click" ToolTip="Close"
                            DockPanel.Dock="Right" HorizontalAlignment="Right"
                            VerticalAlignment="Center" />
                </DockPanel>
            </Border>

            <!-- Content -->
            <Border Grid.Row="1" Style="{StaticResource PanelBorder}" Margin="16,0,16,16">
                <StackPanel>
                    <!-- Enable checkbox -->
                    <CheckBox x:Name="chkEnableSchedule"
                              Content="Enable automatic cache cleaning"
                              Style="{StaticResource DarkCheckBox}"
                              FontSize="14"
                              Checked="ChkEnableSchedule_Changed"
                              Unchecked="ChkEnableSchedule_Changed" />

                    <!-- Schedule Settings group -->
                    <Border BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="16" Margin="0,16,0,0">
                        <StackPanel x:Name="pnlSettings">
                            <TextBlock Text="Schedule settings" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}" Margin="0,0,0,12" />

                            <TextBlock Text="Frequency:" Foreground="{StaticResource SubtextBrush}"
                                       FontSize="12" Margin="0,0,0,4" />
                            <ComboBox x:Name="cmbFrequency" IsEditable="False"
                                      Width="200" HorizontalAlignment="Left"
                                      Background="{StaticResource ButtonBgBrush}"
                                      Foreground="Black" FontSize="13"
                                      SelectionChanged="CmbFrequency_SelectionChanged">
                                <ComboBoxItem Content="Daily" IsSelected="True" />
                                <ComboBoxItem Content="Weekly" />
                                <ComboBoxItem Content="Monthly" />
                            </ComboBox>

                            <!-- Day of week (for Weekly) -->
                            <StackPanel x:Name="pnlDayOfWeek" Visibility="Collapsed" Margin="0,12,0,0">
                                <TextBlock Text="Day of week:" Foreground="{StaticResource SubtextBrush}"
                                           FontSize="12" Margin="0,0,0,4" />
                                <ComboBox x:Name="cmbDayOfWeek" IsEditable="False"
                                          Width="200" HorizontalAlignment="Left"
                                          Background="{StaticResource ButtonBgBrush}"
                                          Foreground="Black" FontSize="13">
                                    <ComboBoxItem Content="Monday" IsSelected="True" />
                                    <ComboBoxItem Content="Tuesday" />
                                    <ComboBoxItem Content="Wednesday" />
                                    <ComboBoxItem Content="Thursday" />
                                    <ComboBoxItem Content="Friday" />
                                    <ComboBoxItem Content="Saturday" />
                                    <ComboBoxItem Content="Sunday" />
                                </ComboBox>
                            </StackPanel>

                            <!-- Day of month (for Monthly) -->
                            <StackPanel x:Name="pnlDayOfMonth" Visibility="Collapsed" Margin="0,12,0,0">
                                <TextBlock Text="Day of month:" Foreground="{StaticResource SubtextBrush}"
                                           FontSize="12" Margin="0,0,0,4" />
                                <ComboBox x:Name="cmbDayOfMonth" IsEditable="False"
                                          Width="200" HorizontalAlignment="Left"
                                          Background="{StaticResource ButtonBgBrush}"
                                          Foreground="Black" FontSize="13" />
                            </StackPanel>

                            <TextBlock Text="Time:" Foreground="{StaticResource SubtextBrush}"
                                       FontSize="12" Margin="0,12,0,4" />
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="txtHour" Text="03" Width="50"
                                         FontSize="14" TextAlignment="Center"
                                         Background="{StaticResource ButtonBgBrush}"
                                         Foreground="{StaticResource TextBrush}"
                                         BorderBrush="{StaticResource PanelBorderBrush}"
                                         Padding="4" MaxLength="2" />
                                <TextBlock Text=":" FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource TextBrush}"
                                           VerticalAlignment="Center" Margin="6,0" />
                                <TextBox x:Name="txtMinute" Text="00" Width="50"
                                         FontSize="14" TextAlignment="Center"
                                         Background="{StaticResource ButtonBgBrush}"
                                         Foreground="{StaticResource TextBrush}"
                                         BorderBrush="{StaticResource PanelBorderBrush}"
                                         Padding="4" MaxLength="2" />
                            </StackPanel>

                            <Button x:Name="btnApply" Content="Apply"
                                    Style="{StaticResource AccentButton}"
                                    Padding="16,10" Margin="0,16,0,0"
                                    HorizontalAlignment="Left"
                                    Click="BtnApply_Click" />
                        </StackPanel>
                    </Border>

                    <!-- Info text -->
                    <TextBlock Text="Note: Creating scheduled tasks requires administrator privileges. The scheduler will automatically clean all existing caches at the specified time."
                               Foreground="{StaticResource SubtextBrush}" FontSize="11"
                               TextWrapping="Wrap" Margin="0,16,0,0" />

                    <!-- Status -->
                    <TextBlock x:Name="lblStatus" Text="Ready"
                               Foreground="{StaticResource SubtextBrush}"
                               FontSize="12" Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
